{
    "ports": [
        {
            "port": "COM3",
            "baudrate": 115200
        },
        {
            "port": "COM4",
            "baudrate": 115200
        },
        {
            "port": "COM6",
            "baudrate": 115200
        }
    ],
    "subsystems": [
        {
            "name": "EngineNode",
            "display_name": "🚗 Engine Controller",
            "variables": [
                {
                    "name": "rpm",
                    "display_name": "RPM Rate",
                    "column_index": "0",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "RPM",
                    "is_numerical": true
                },
                {
                    "name": "temp",
                    "display_name": "Core Temp",
                    "column_index": "1",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "°C",
                    "is_numerical": true
                },
                {
                    "name": "batt",
                    "display_name": "Bus Voltage",
                    "column_index": "2",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "V",
                    "is_numerical": true
                }
            ],
            "thresholds": {
                "ovp_var": "",
                "ovp_val": 154.0,
                "ocp_var": "",
                "ocp_val": 50.0,
                "otp_var": "temp",
                "otp_val": 80.0,
                "standby_var": "",
                "standby_val": 1.0
            },
            "temp_mosfet_var": "",
            "temp_transformer_var": ""
        },
        {
            "name": "BatteryNode",
            "display_name": "🔋 Power Subsystem",
            "variables": [
                {
                    "name": "vin",
                    "display_name": "Vin Bus",
                    "column_index": "0",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "V",
                    "is_numerical": true
                },
                {
                    "name": "iin",
                    "display_name": "Iin Bus",
                    "column_index": "1",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "A",
                    "is_numerical": true
                },
                {
                    "name": "vout",
                    "display_name": "Vout Batt",
                    "column_index": "2",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "V",
                    "is_numerical": true
                },
                {
                    "name": "iout",
                    "display_name": "Iout Batt",
                    "column_index": "3",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "A",
                    "is_numerical": true
                },
                {
                    "name": "t_mos",
                    "display_name": "MOSFET Temp",
                    "column_index": "4",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "°C",
                    "is_numerical": true
                },
                {
                    "name": "t_trans",
                    "display_name": "Transformer Temp",
                    "column_index": "5",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "°C",
                    "is_numerical": true
                },
                {
                    "name": "stby",
                    "display_name": "Standby Flag",
                    "column_index": "6",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "",
                    "is_numerical": true
                },
                {
                    "name": "pin",
                    "display_name": "Pin Computed",
                    "column_index": "-1",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "W",
                    "is_numerical": true
                },
                {
                    "name": "pout",
                    "display_name": "Pout Computed",
                    "column_index": "-1",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "W",
                    "is_numerical": true
                },
                {
                    "name": "eff",
                    "display_name": "Efficiency",
                    "column_index": "-1",
                    "gain": 1.0,
                    "offset": 0.0,
                    "unit": "%",
                    "is_numerical": true
                }
            ],
            "thresholds": {
                "ovp_var": "vin",
                "ovp_val": 401.0,
                "ocp_var": "iin",
                "ocp_val": 12.0,
                "otp_var": "t_mos",
                "otp_val": 90.0,
                "standby_var": "stby",
                "standby_val": 1.0
            },
            "temp_mosfet_var": "t_mos",
            "temp_transformer_var": "t_trans"
        }
    ],
    "routing_rules": [
        {
            "port": "COM3",
            "type": "PREFIX",
            "pattern": "ENG",
            "target": "EngineNode"
        },
        {
            "port": "COM4",
            "type": "PREFIX",
            "pattern": "BAT",
            "target": "BatteryNode"
        }
    ],
    "linking_formulas": [
        {
            "target_sub": "BatteryNode",
            "target_var": "pin",
            "formula": "[BatteryNode].vin * [BatteryNode].iin"
        },
        {
            "target_sub": "BatteryNode",
            "target_var": "pout",
            "formula": "[BatteryNode].vout * [BatteryNode].iout"
        },
        {
            "target_sub": "BatteryNode",
            "target_var": "eff",
            "formula": "([BatteryNode].pout / ([BatteryNode].pin + 0.001)) * 100"
        }
    ],
    "active_plugins": [
        "telemetry_cards",
        "trend_charts",
        "service_console",
        "parameter_manager",
        "mcu_terminal"
    ]
}
